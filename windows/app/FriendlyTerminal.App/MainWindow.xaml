<Window
    x:Class="FriendlyTerminal.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:views="using:FriendlyTerminal.App.Views"
    Title="FriendlyTerminal">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border
            Grid.Column="0"
            Background="{ThemeResource SolidBackgroundFillColorBase}"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,0,1,0">
            <views:SidebarColumnView x:Name="Sidebar" />
        </Border>

        <controls:WebView2 x:Name="Terminal" Grid.Column="1" />
    </Grid>
</Window>
